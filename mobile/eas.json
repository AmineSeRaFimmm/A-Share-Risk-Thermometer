{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://amineserafimmm.github.io/A-Share-Risk-Thermometer/",
        "EXPO_PUBLIC_ALLOW_GITHUB": "0"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://amineserafimmm.github.io/A-Share-Risk-Thermometer/",
        "EXPO_PUBLIC_ALLOW_GITHUB": "0"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://amineserafimmm.github.io/A-Share-Risk-Thermometer/",
        "EXPO_PUBLIC_ALLOW_GITHUB": "0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
